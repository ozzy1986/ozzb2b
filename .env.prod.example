OZZB2B_ENV=production

# The VPS already runs Postgres and Redis on localhost.
# Inside Docker, we reach the host via host.docker.internal.
OZZB2B_DATABASE_URL=postgresql+asyncpg://ozzb2b:CHANGE_ME@host.docker.internal:5432/ozzb2b
OZZB2B_REDIS_URL=redis://host.docker.internal:6379/3

OZZB2B_MEILISEARCH_URL=http://meilisearch:7700
OZZB2B_MEILISEARCH_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

MEILI_MASTER_KEY=CHANGE_ME_TO_A_LONG_RANDOM_STRING

OZZB2B_JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
OZZB2B_JWT_ACCESS_TTL_SECONDS=900
OZZB2B_JWT_REFRESH_TTL_SECONDS=2592000

OZZB2B_CORS_ORIGINS=https://ozzb2b.com,https://www.ozzb2b.com,https://api.ozzb2b.com

OZZB2B_LOG_LEVEL=INFO

NEXT_PUBLIC_OZZB2B_API_URL=https://api.ozzb2b.com
