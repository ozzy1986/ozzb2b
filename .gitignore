apps/web/coverage/

# ---- Go ----
/apps/chat/bin/
/apps/events/bin/
*.test
# `*.out` would match Go test coverage. We only want to ignore Go binary .out,
# not repo-relative coverage files like scripts may produce intentionally.
apps/chat/coverage.out
apps/events/coverage.out

# ---- Rust ----
/apps/matcher/target/
**/*.rs.bk

# ---- Docker / data volumes ----
/infra/data/
/infra/volumes/

