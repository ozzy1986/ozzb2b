# ---- Secrets & local config ----
.env
.env.*
!.env.example
!.env.prod.example
*.local
credentials.json
# Alertmanager config is rendered on the VPS from the .tmpl file with secrets
# injected from /root/.ozzb2b_secrets. Never commit the rendered file.
infra/alertmanager/alertmanager.yml

# ---- Legacy WordPress secrets ----
wp-config.php

# ---- Legacy WordPress runtime data ----
legacy/wp-content/uploads/
legacy/wp-content/cache/
legacy/wp-content/upgrade/
legacy/wp-content/backup*/
legacy/wp-content/blogs.dir/
legacy/wp-content/advanced-cache.php
legacy/wp-content/wp-cache-config.php
legacy/wp-content/object-cache.php

