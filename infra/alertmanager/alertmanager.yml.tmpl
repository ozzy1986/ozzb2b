# Alertmanager config template.
#
# The real `alertmanager.yml` file is rendered on the VPS by
# deploy/vps_apply_stack.sh from this template, substituting the
# Telegram bot token + chat id out of /root/.ozzb2b_secrets.
# The rendered file is gitignored so secrets never land in the repo.
#
# Placeholders:
#   __TELEGRAM_BOT_TOKEN__   - from OZZB2B_TELEGRAM_BOT_TOKEN
#   __TELEGRAM_CHAT_ID__     - from OZZB2B_TELEGRAM_CHAT_ID (numeric)

global:
  resolve_timeout: 5m

route:
  receiver: telegram
  group_by: ["alertname", "severity"]
  group_wait: 30s
  group_interval: 5m
  repeat_interval: 3h
  routes:
    - matchers:
        - severity = "critical"
      receiver: telegram
      group_wait: 10s
      repeat_interval: 1h

receivers:
  - name: telegram
    telegram_configs:
      - send_resolved: true
        bot_token: "__TELEGRAM_BOT_TOKEN__"
        chat_id: __TELEGRAM_CHAT_ID__
        parse_mode: HTML
        message: |
          <b>{{ .Status | toUpper }}</b> — {{ .CommonLabels.severity | toUpper }}
          {{ range .Alerts -}}
          <b>{{ .Labels.alertname }}</b>
          {{ .Annotations.summary }}
          <i>{{ .Annotations.description }}</i>
          {{ with .Labels.instance }}instance: <code>{{ . }}</code>
          {{ end -}}
          {{ with .Labels.job }}job: <code>{{ . }}</code>
          {{ end -}}
          {{ end }}

inhibit_rules:
  - source_matchers: [severity="critical"]
    target_matchers: [severity="warning"]
    equal: ["alertname", "instance"]
